# Shared zsh config (safe to commit)

# PATH
export PATH="$HOME/.dotfiles/bin:$HOME/.local/bin:$HOME/bin:$PATH"

# Initialise completions before anything that registers via `compdef`
# (mise activate, direnv hook, atuin/zoxide/starship init all use it).
autoload -Uz compinit && compinit

# Activate mise (if present)
command -v mise >/dev/null && eval "$(mise activate zsh)"

# History (sane defaults)
setopt hist_ignore_dups
setopt share_history
HISTSIZE=100000
SAVEHIST=100000
HISTFILE=~/.zsh_history

# Terminal title (OSC 0; widely supported)
set_term_title() {
  case "$TERM" in
    screen*) return ;;
  esac
  print -Pn "\e]0;%n@%m:%~\a"
}
precmd_functions+=(set_term_title)

command -v direnv >/dev/null && eval "$(direnv hook zsh)"

# Plugins (Homebrew paths)
[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] \
  && source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] \
  && source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# Local scripts
export PATH="$HOME/Scripts:$PATH"

# Editor
export EDITOR="zed-preview --wait"
export VISUAL="zed-preview --wait"
export GIT_EDITOR="zed-preview --wait"
export BETTER_ERRORS_EDITOR="zed-preview --wait"
export BETTER_ERRORS_EDITOR_URL="zed-preview://file/%{file}:%{line}"

# Prompt + history + dir jumping
command -v starship >/dev/null && eval "$(starship init zsh)"
if command -v atuin >/dev/null; then
  eval "$(atuin init zsh)"
  bindkey '^[[A' atuin-up-search
fi

# tinyprompt - shrink the prompt to a bare "> " for the current session, handy
# for copy/pasting clean command+output. starship paints the prompt via its
# precmd hook, so we drop that hook and set a static PROMPT; run it again to
# restore. A fresh shell (or `exec zsh`) always comes back to normal.
#
# Usage:  tinyprompt        # toggle between "> " and your normal prompt
tinyprompt() {
  emulate -L zsh
  autoload -Uz add-zsh-hook

  if [[ -z $_TINYPROMPT_ON ]]; then
    _TINYPROMPT_SAVED_PS1=$PROMPT
    _TINYPROMPT_SAVED_RPS1=$RPROMPT
    add-zsh-hook -d precmd prompt_starship_precmd
    PROMPT='> '
    RPROMPT=''
    _TINYPROMPT_ON=1
  else
    add-zsh-hook precmd prompt_starship_precmd
    PROMPT=$_TINYPROMPT_SAVED_PS1
    RPROMPT=$_TINYPROMPT_SAVED_RPS1
    unset _TINYPROMPT_ON _TINYPROMPT_SAVED_PS1 _TINYPROMPT_SAVED_RPS1
  fi
}

# Build flags (libxml2)
export LDFLAGS="-L/opt/homebrew/opt/libxml2/lib"
export CPPFLAGS="-I/opt/homebrew/opt/libxml2/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/libxml2/lib/pkgconfig"
export PATH="/opt/homebrew/opt/libxml2/bin:$PATH"

# pipx
export PATH="$PATH:/Users/james/.local/bin"

# Amp CLI
export PATH="/Users/james/.amp/bin:$PATH"

# Aliases
command -v eza    >/dev/null && alias ls='eza --icons --group-directories-first'
command -v bat    >/dev/null && alias cat='bat'
command -v zoxide >/dev/null && alias cd='z'
alias zed='zed-preview'
alias bu='bundle update --all'
alias bup='git pull && bundle update --all && git add Gemfile.lock && git commit -m "Update dependencies" && git push'

# zoxide is initialised last (its hook must register after direnv/mise). The
# doctor check false-positives in non-interactive harness shells that reset
# chpwd_functions, so disable the nag — the init below is already correctly ordered.
export _ZO_DOCTOR=0
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
