TM_GIT         = "/usr/bin/git"
excludeFiles   = "*.{so,pyc,o,scssc}"
excludeDirectories = "build,dist,tmp,log"

# show the path to the current tab's file in the window title 
# (replace the 2 instances of 'username' in the string below 
# with your mac username).
windowTitle    = "$TM_DISPLAYNAME${TM_DIRECTORY/\A(?:\/Users\/James\w+\/?(.*)|(.+))\z/${2:? – ${2/\A\/Users\/James/~/}:${1/\A(?=.)/ – /}}/}"

fontName       = "Monaco" 
fontSize       = 13
tabSize        = 2
softTabs       = true
wrapColumn     = "Use Window Frame"
sofWrap        = false
showInvisibles = false

[ *.{txt,md,mdown,markdown} ]
spellChecking  = true
tabSize        = 4
softWrap         = true

[ .git/COMMIT_EDITMSG ]
softWrap         = true
spellChecking    = true
spellingLanguage = 'en'

[ "{README,INSTALL,LICENSE,TODO}" ] 
fileType         = "text.plain"

[ *.rb ]
fileType         = "source.ruby.rails"

[ *_spec.rb ]
fileType         = "source.ruby.rspec"
